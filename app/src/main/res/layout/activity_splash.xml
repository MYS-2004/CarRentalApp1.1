<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Background accent circle -->
    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:background="@drawable/circle_accent_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="-100dp"
        android:layout_marginBottom="-100dp"
        android:alpha="0.06"/>

    <!-- Logo Icon -->
    <TextView
        android:id="@+id/logoIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="🚗"
        android:textSize="48sp"
        android:gravity="center"
        android:background="@drawable/logo_bg"
        app:layout_constraintBottom_toTopOf="@id/appName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="20dp"/>

    <!-- App Name -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DriveNow"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toTopOf="@id/appTagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- Accent dot in name -->
    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/dot_accent"
        app:layout_constraintTop_toTopOf="@id/appName"
        app:layout_constraintStart_toEndOf="@id/appName"
        android:layout_marginStart="2dp"
        android:layout_marginTop="4dp"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/appTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="استأجر سيارتك في لحظات"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:letterSpacing="0.02"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadingBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="120dp"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="60dp"/>

    <!-- Version -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
